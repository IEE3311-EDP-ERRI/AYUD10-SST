                Variable      "RuntimeCheck"
                Value         "2"
                Show          off
              }
              Parameter {
                Variable      "HighlightLevel"
                Value         "0"
                Show          off
              }
              Parameter {
                Variable      "Declarations"
                Value         "#include <float.h>\n"
"#include <stdio.h>\n"
"#include <math.h>\n"
"\n"
"// Recordar Ts_mod = 1/( 200e6) ;\n"
"\n"
" const float PI   = 3.1415926535897932384626433832795; \n"
"\n"
"float D1, D2, D3, D1os, D2os, D3os, x12, x13, x23 ; \n"
"float m1, m2, m3 , m1com, m2com, m3com ; \n"
"float ph1, ph1com, ph2, ph2com, ph3, ph3com ; \n"
"\n"
"float cuentas = 20000 ; \n"
"int pasos = 10000 ; \n"
"// 50 kHz con triangular son 1000 pasos o cuentas \n"
"\n"
"\n"
"float saturacion_normal(float valor, float lim_inf, float lim_sup) \n"
"{  \n"
"// float valor, lim_sup, lim_inf ;\n"
"   if (valor>lim_sup) \n"
"   {  valor = lim_sup ; }\n"
"   else if (valor<lim_inf) \n"
"   {  valor = lim_inf ; }\n"
"   return valor ; \n"
"}\n"
"\n"
"float verificar_ph_0a1( float ph )\n"
"{\n"
"\tif (ph < 0){\n"
"\t\treturn ph + 1 ;\n"
"\t}\n"
"\telse if (ph >= 1){\n"
"\t\treturn ph - 1 ;\n"
"\t}\n"
"\telse{\n"
"\t\treturn ph ;\n"
"\t}\n"
"}"
                Show          off
              }
              Parameter {
                Variable      "StartFcn"
                Value         ""
                Show          off
              }
              Parameter {
                Variable      "OutputFcn"
                Value         "D1  = InputSignal(0,0) ;\n"
"D2  = InputSignal(0,1) ;\n"
"x12 = InputSignal(0,2) ;\n"
"\n"
"m1 = D1 ; \n"
"m2 = D2 ; \n"
"m1com = D1 ; \n"
"m2com = D2 ; \n"
"\n"
"ph1 = -x12/(2*PI)  ;  \n"
"ph2 =      0       ;\n"
"ph1com = 0.5 - x12/(2*PI)  ;\n"
"ph2com = 0.5 -    0        ;\n"
"\n"
"ph1 = verificar_ph_0a1( ph1 ) ; \n"
"ph2 = verificar_ph_0a1( ph2 ) ; \n"
"ph1com = verificar_ph_0a1( ph1com ) ; \n"
"ph2com = verificar_ph_0a1( ph2com ) ; \n"
"\n"
"m1     =     round(m1*pasos) / pasos ; \n"
"ph1    =    round(ph1*pasos) / pasos ; \n"
"m1com  =  round(m1com*pasos) / pasos ; \n"
"ph1com = round(ph1com*pasos) / pasos ; \n"
"m2     =     round(m2*pasos) / pasos ; \n"
"ph2    =    round(ph2*pasos) / pasos ; \n"
"m2com  =  round(m2com*pasos) / pasos ; \n"
"ph2com = round(ph2com*pasos) / pasos ; \n"
"\n"
"\n"
"OutputSignal(0,0) = m1 ; \n"
"OutputSignal(0,1) = ph1 ; \n"
"OutputSignal(0,2) = m1com ; \n"
"OutputSignal(0,3) = ph1com ; \n"
"\n"
"OutputSignal(1,0) = m2 ; \n"
"OutputSignal(1,1) = ph2 ;\n"
"OutputSignal(1,2) = m2com ; \n"
"OutputSignal(1,3) = ph2com ; \n"
                Show          off
              }
              Parameter {
                Variable      "UpdateFcn"
                Value         ""
                Show          off
              }
              Parameter {
                Variable      "DerivativeFcn"
                Value         ""
                Show          off
              }
              Parameter {
                Variable      "TerminateFcn"
                Value         ""
                Show          off
              }
              Parameter {
                Variable      "StoreCustomStateFcn"
                Value         ""
                Show          off
              }
              Parameter {
                Variable      "RestoreCustomStateFcn"
                Value         ""
                Show          off
              }
            }
