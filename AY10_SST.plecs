                Component {
                  Type          CScript
                  Name          "PI_code_full"
                  Show          on
                  Position      [220, 60]
                  Direction     up
                  Flipped       off
                  LabelPosition north
                  Parameter {
                    Variable      "DialogGeometry"
                    Value         "[523 340 422 314]"
                    Show          off
                  }
                  Parameter {
                    Variable      "NumInputs"
                    Value         "9"
                    Show          off
                  }
                  Parameter {
                    Variable      "NumOutputs"
                    Value         "1"
                    Show          off
                  }
                  Parameter {
                    Variable      "NumContStates"
                    Value         "0"
                    Show          off
                  }
                  Parameter {
                    Variable      "NumDiscStates"
                    Value         "0"
                    Show          off
                  }
                  Parameter {
                    Variable      "NumZCSignals"
                    Value         "0"
                    Show          off
                  }
                  Parameter {
                    Variable      "DirectFeedthrough"
                    Value         "1"
                    Show          off
                  }
                  Parameter {
                    Variable      "Ts"
                    Value         "Ts_control"
                    Show          off
                  }
                  Parameter {
                    Variable      "TerminalBasedSampleTimes"
                    Value         "1"
                    Show          off
                  }
                  Parameter {
                    Variable      "Parameters"
                    Value         "Ts_control"
                    Show          off
                  }
                  Parameter {
                    Variable      "LangStandard"
                    Value         "2"
                    Show          off
                  }
                  Parameter {
                    Variable      "GnuExtensions"
                    Value         "1"
                    Show          off
                  }
                  Parameter {
                    Variable      "RuntimeCheck"
                    Value         "2"
                    Show          off
                  }
                  Parameter {
                    Variable      "HighlightLevel"
                    Value         "0"
                    Show          off
                  }
                  Parameter {
                    Variable      "Declarations"
                    Value         "#include <float.h>\n"
"#include <stdio.h>\n"
"#include <math.h>\n"
"\n"
"// CONSTANT DECLARATION\n"
"// Input\n"
"#define Ts  \tParamRealData(0,0)\n"
"//#define Kp  \tParamRealData(1,0)\n"
"//#define Ki  \tParamRealData(2,0)\n"
"\n"
"// Constant\n"
"#define PI    3.14159265\n"
"\n"
"// VARIABLE DECLARATION\n"
"int enable, reset, enable_ff ; \n"
"float error, error_ant , ypi , ypi_ant ;\n"
"float kp, ki, ts  ; \n"
"float ff, sat_pos , sat_neg ;\n"
"\n"
"\n"
"\n"
"\n"
"// DEFINITION STRUCTURES FOR CONTROLLER  \n"
"float PI_array[4] = {0,0,0,0} ;  \n"
" \n"
"\n"
"\n"
"// FUNCTION DECLARATION\n"
"void calculation_pi_array_full(float valores[4], int enable, int reset, int e"
"nable_ff, float kp, float ki, float ts, float ff, float sat_pos, float sat_ne"
"g); \n"
"\n"
"\n"
"\n"
"// FUNCTION DEFINITIONS\n"
"\n"
"\n"
"void calculation_pi_array_full(float valores[4], int enable, int reset, int e"
"nable_ff, float kp, float ki, float ts, float ff, float sat_pos, float sat_ne"
"g)\n"
"{\n"
"\t// y[k] = y[k-1] + e[k]*a1 + e[k-1]*a2 ; \n"
"\t// result[4] = [ y[k] ,  y[k-1]  , e[k]  ,  e[k-1] ]   =  {  0  , 1  ,  2  "
" 3  }\n"
"\t// result[0] = result[1] + (kp+ki*ts/2)*result[2] + (-kp+ki*ts/2)*result[3]"
" ;\n"
"\t\n"
"\t// Reset error acumulado\n"
"   if(reset==1)\n"
"   {\n"
"    \tvalores[3] = 0.0 ; // error anterior \n"
"   }\t\n"
"\t\n"
"\t// Enable FeedForward \n"
"\tif (enable_ff==0){\n"
"    \tff = 0 ; \n"
"   }\t\n"
"   \n"
"\t// Enable calculo PI \n"
"   if(enable==1){\n"
"   \t// Calculo PI = Proporcional + Integral \n"
"   \tvalores[0] = valores[1] + (kp+1*ki*ts/2)*valores[2] + (-kp+1*ki*ts/2)*va"
"lores[3] ;\n"
"   \t\n"
"   \t//Anti-Windup\n"
"\t\tif( (valores[0] + ff) <= sat_pos && (valores[0] + ff) >= sat_neg)\n"
"\t\t{ \n"
"\t\t\tvalores[1] = valores[0] ; // Feed y[k-1] = y[k] ;\t\t\n"
"\t\t\tvalores[0] = valores[0] + ff\t;\t\n"
"\t\t}\n"
"\t\telse // saturado \n"
"\t\t{\n"
"\t\t\tvalores[1] = ( valores[1] + (kp)*valores[2] + (-kp)*valores[3] ) ; // F"
"eed sin parte integral \n"
"\t\t\t//Saturation\n"
"\t\t\tif (valores[0] + ff > sat_pos)\n"
"\t\t\t{\t\n"
"\t\t\t\tvalores[0] = sat_pos  ;  // Positive saturation\n"
"\t\t\t} \n"
"\t\t\telse if (valores[0] + ff < sat_neg)\n"
"\t\t\t{\t\n"
"\t\t\t\tvalores[0] = sat_neg  ;  // Negative saturation\n"
"\t\t\t}\n"
"\t\t}\t \n"
"   }\n"
"   else {\n"
"    \tvalores[0] = 0.0 ; // actuacion actual\n"
"    \tvalores[1] = 0.0 ; // actuacion anterior\n"
"    \tvalores[2] = 0.0 ; // error actual\n"
"   }\t\n"
"\t\n"
"\t// Feed error\n"
"\tvalores[3] = valores[2] ; // Feed e[k-1] = e[k] ;\n"
"}\n"
                    Show          off
                  }
                  Parameter {
                    Variable      "StartFcn"
                    Value         ""
                    Show          off
                  }
                  Parameter {
                    Variable      "OutputFcn"
                    Value         "// OUTPUT CONTROLADOR PI \n"
"\n"
"// MEDICIONES\n"
"error    = InputSignal(0,0);\n"
"ff       = InputSignal(0,1);\n"
"sat_pos  = InputSignal(0,2);\n"
"sat_neg  = InputSignal(0,3);\n"
"kp       = InputSignal(0,4);\n"
"ki       = InputSignal(0,5);\n"
"enable = InputSignal(0,6);\n"
"reset  = InputSignal(0,7);\n"
"enable_ff = InputSignal(0,8);\n"
"\n"
"// CALCULO PI SIMPLE\n"
"PI_array[2] = error ; \n"
"calculation_pi_array_full(PI_array, enable, reset, enable_ff, kp, ki, Ts, ff,"
" sat_pos, sat_neg);\n"
"\n"
"\n"
"// SALIDA\n"
"Output(0) = PI_array[0] ; // Salida"
                    Show          off
                  }
                  Parameter {
                    Variable      "UpdateFcn"
                    Value         ""
                    Show          off
                  }
                  Parameter {
                    Variable      "DerivativeFcn"
                    Value         ""
                    Show          off
                  }
                  Parameter {
                    Variable      "TerminateFcn"
                    Value         ""
                    Show          off
                  }
                  Parameter {
                    Variable      "StoreCustomStateFcn"
                    Value         ""
                    Show          off
                  }
